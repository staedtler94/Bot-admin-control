{
  "name": "bot-admin-control-plane",
  "version": "1.0.0",
  "description": "bot setup for admin control plane",
  "main": "index.js",
  "scripts": {
    "start": "node generate.mjs",
    "setup": "node scripts/setup-dev.mjs",
    "setup:help": "node scripts/setup-dev.mjs --skip-install",
    "docker:dynamodb": "docker-compose up -d dynamodb",
    "seed:database": "node scripts/seed-database.mjs",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "typecheck:frontend": "npm run typecheck --prefix frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend",
    "check:backend": "npm run check --prefix backend",
    "check:frontend": "npm run check --prefix frontend",
    "check:all": "npm run typecheck:backend && npm run typecheck:frontend && npm run lint:backend && npm run lint:frontend"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "moment": "^2.30.1"
  }
}
